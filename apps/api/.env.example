# REVYX API — environment template
# Copy to .env (gitignored) and fill values for local dev.

# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database
DATABASE_URL=postgres://revyx_app:dev_password@localhost:5432/revyx_dev
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379

# JWT RS256 keys (PEM format, base64-encoded or path)
# Generate: openssl genrsa -out jwt-rs256-priv.pem 2048 && openssl rsa -in jwt-rs256-priv.pem -pubout -out jwt-rs256-pub.pem
JWT_PRIVATE_KEY_PATH=./secrets/jwt-rs256-priv.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-rs256-pub.pem
JWT_KEY_ID=k1
JWT_ISSUER=https://api.revyx.app
JWT_AUDIENCE=revyx-api
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Webhook secrets (per provider HMAC-SHA256)
META_WEBHOOK_SECRET=
GOOGLE_WEBHOOK_SECRET=
OLX_WEBHOOK_SECRET=

# Rate limits (overridable)
THROTTLE_PUBLIC_LIMIT=20
THROTTLE_PUBLIC_TTL=60000
THROTTLE_INTERNAL_LIMIT=1000
THROTTLE_INTERNAL_TTL=60000

# GDPR
GDPR_RETENTION_DAYS=1095
PRIVACY_POLICY_VERSION=1.0.0
