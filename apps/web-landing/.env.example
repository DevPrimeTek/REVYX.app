# REVYX web-landing — environment variables
# Copy to .env.local for local dev, and set the same in Vercel Project Settings.

# --- Public site config ---
# Live demo URL shown by the "Try the demo" buttons.
NEXT_PUBLIC_DEMO_URL=https://demo.revyx.app

# --- Supabase (feedback questionnaire storage) ---
# Project REST URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service role key — SERVER ONLY. Never expose to the browser / NEXT_PUBLIC_*.
# Used by the /api/feedback route handler to insert rows into the feedback table.
SUPABASE_SERVICE_ROLE_KEY=
