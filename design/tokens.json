{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "REVYX Design Tokens",
    "version": "1.0.0",
    "stage": "M0.S1 — Design System direct-to-code",
    "source": "docs/brand-configs/revyx.md v1.0.0 (canonical)",
    "platform": "WEB primary (M0); MOBILE companion derives from same tokens at M2.S3",
    "updated": "2026-05",
    "license": "CONFIDENTIAL · Internal Use · (c) 2026 REVYX · ITPRO SYSTEM SRL"
  },
  "color": {
    "navy": {
      "base":   { "hex": "#0C1428", "rgb": "12 20 40",   "hsl": "222 54% 10%", "role": "Primary background" },
      "deep":   { "hex": "#080E1C", "rgb": "8 14 28",    "hsl": "222 56% 7%",  "role": "Deepest surface (covers, dropdowns)" },
      "mid":    { "hex": "#111D35", "rgb": "17 29 53",   "hsl": "222 51% 14%", "role": "Cards, panels" },
      "card":   { "hex": "#152038", "rgb": "21 32 56",   "hsl": "222 45% 15%", "role": "Elevated cards" },
      "hover":  { "hex": "#1A2844", "rgb": "26 40 68",   "hsl": "222 45% 18%", "role": "Hover state" }
    },
    "gold": {
      "base":   { "hex": "#C9870A", "rgb": "201 135 10", "hsl": "39 91% 41%",  "role": "Primary accent — CTAs, headers" },
      "light":  { "hex": "#E6A020", "rgb": "230 160 32", "hsl": "39 78% 51%",  "role": "Lighter accent" },
      "bright": { "hex": "#F5B830", "rgb": "245 184 48", "hsl": "40 91% 57%",  "role": "Bright glow effects" },
      "dark":   { "hex": "#8A5C06", "rgb": "138 92 6",   "hsl": "39 92% 28%",  "role": "Gradient start" }
    },
    "border": {
      "base":   { "hex": "#1E2E48", "role": "Standard border" },
      "light":  { "hex": "#263A58", "role": "Hover/focus border" },
      "gold":   { "hex": "#C9870A38", "role": "Gold border (~22% opacity)" },
      "goldPale": { "hex": "#C9870A14", "role": "Gold pale background (~8%)" }
    },
    "text": {
      "h":       { "hex": "#F0F4FA", "alias": "t1", "role": "Headings on navy" },
      "primary": { "hex": "#D8E2F0", "alias": "t2", "role": "Body primary" },
      "secondary": { "hex": "#8FA8CC", "alias": "t3", "role": "Secondary labels" },
      "muted":   { "hex": "#849AB8", "alias": "t4", "role": "Muted / disabled (WCAG AA ≥4.5 on all navy surfaces)" },
      "white":   { "hex": "#FFFFFF", "role": "Pure white" }
    },
    "status": {
      "green":   { "hex": "#0FBA7F", "role": "Success · healthy deal · AC pass" },
      "amber":   { "hex": "#E8950A", "role": "Attention · review required" },
      "red":     { "hex": "#F26565", "role": "Error · deal at risk · critical (WCAG AA on navy surfaces)" },
      "blue":    { "hex": "#60A5FA", "role": "Info · AI system action (WCAG AA on navy surfaces)" }
    },
    "actor": {
      "seller":  { "hex": "#F59E0B", "alias": "sel", "role": "Owner / seller" },
      "agent":   { "hex": "#C9870A", "alias": "agt", "role": "Real estate agent" },
      "ai":      { "hex": "#60A5FA", "alias": "ai",  "role": "REVYX AI system" },
      "buyer":   { "hex": "#10B981", "alias": "buy", "role": "Buyer / client" },
      "manager": { "hex": "#EC4899", "alias": "mgr", "role": "Agency manager" },
      "bank":    { "hex": "#8B5CF6", "alias": "bnk", "role": "Bank / financier" },
      "notary":  { "hex": "#EF4444", "alias": "not", "role": "Notary" },
      "social":  { "hex": "#FF6B35", "alias": "soc", "role": "Platforms & social" }
    },
    "leadTemperature": {
      "cold":      { "hex": "#60A5FA", "threshold": "LS < 0.40",     "label": "Rece" },
      "warm":      { "hex": "#F59E0B", "threshold": "0.40 – 0.60",   "label": "Warm" },
      "qualified": { "hex": "#C9870A", "threshold": "0.60 – 0.75",   "label": "Calificat" },
      "hot":       { "hex": "#F26565", "threshold": "LS ≥ 0.75",     "label": "HOT", "effect": "pulse animation" }
    }
  },
  "typography": {
    "family": {
      "display": { "stack": "'Bebas Neue', 'Oswald', 'Impact', sans-serif", "weights": [400], "role": "Display / Heading", "source": "brand-configs/revyx.md §3" },
      "body":    { "stack": "'Montserrat', 'Inter', system-ui, -apple-system, sans-serif", "weights": [300, 400, 600, 700, 800, 900], "role": "Body / UI" },
      "mono":    { "stack": "'JetBrains Mono', 'Fira Code', ui-monospace, monospace", "weights": [400, 500], "role": "Code / IDs / scores / mono labels" }
    },
    "scale": {
      "coverTitle":   { "family": "display", "size": "clamp(64px, 10vw, 130px)", "lineHeight": "1",   "letterSpacing": "0.02em", "role": "Page cover title" },
      "coverSub":     { "family": "display", "size": "clamp(18px, 3vw, 28px)",   "lineHeight": "1.1", "role": "Cover subtitle" },
      "sectionTitle": { "family": "display", "size": "clamp(44px, 6vw, 80px)",   "lineHeight": "1.05","role": "Section heading" },
      "h1":           { "family": "body",    "size": "32px", "weight": 700, "lineHeight": "1.2" },
      "h2":           { "family": "body",    "size": "24px", "weight": 700, "lineHeight": "1.3" },
      "h3":           { "family": "body",    "size": "18px", "weight": 600, "lineHeight": "1.4" },
      "body":         { "family": "body",    "size": "14px", "weight": 400, "lineHeight": "1.7" },
      "bodySmall":    { "family": "body",    "size": "12px", "weight": 400, "lineHeight": "1.5" },
      "labelMono":    { "family": "mono",    "size": "10px", "weight": 500, "letterSpacing": "0.25em", "transform": "uppercase", "role": "Categorical labels" },
      "badgeMono":    { "family": "mono",    "size": "9px",  "weight": 500, "letterSpacing": "0.15em", "transform": "uppercase", "role": "Badge text" },
      "score":        { "family": "mono",    "size": "14px", "weight": 500, "role": "Numeric scores (LS, PS, DP, etc.)" }
    }
  },
  "spacing": {
    "base": 8,
    "scale": {
      "sp1":  "8px",
      "sp2":  "16px",
      "sp3":  "24px",
      "sp4":  "32px",
      "sp5":  "40px",
      "sp6":  "48px",
      "sp8":  "64px",
      "sp10": "80px",
      "sp12": "96px",
      "sp16": "128px"
    },
    "note": "8px base grid per brand-config §4. (Prompt mentioned 4px grid; resolved to 8px per canonical brand source.)"
  },
  "radius": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "14px",
    "xl":   "20px",
    "pill": "100px"
  },
  "shadow": {
    "none":  "none",
    "sm":    "0 1px 2px 0 rgba(0,0,0,0.4)",
    "md":    "0 4px 12px 0 rgba(0,0,0,0.45)",
    "lg":    "0 12px 32px 0 rgba(0,0,0,0.55)",
    "gold":  "0 0 24px 0 rgba(201,135,10,0.35)",
    "goldGlow": "0 0 64px 0 rgba(245,184,48,0.18)"
  },
  "motion": {
    "duration": {
      "instant": "80ms",
      "fast":    "160ms",
      "normal":  "240ms",
      "slow":    "400ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0.0, 0.0, 1.0)",
      "decel":    "cubic-bezier(0.0, 0.0, 0.2, 1.0)",
      "accel":    "cubic-bezier(0.4, 0.0, 1.0, 1.0)"
    }
  },
  "breakpoint": {
    "sm":  "640px",
    "md":  "768px",
    "lg":  "1024px",
    "xl":  "1280px",
    "2xl": "1536px"
  },
  "zIndex": {
    "base":     0,
    "dropdown": 10,
    "sticky":   20,
    "header":   30,
    "overlay":  40,
    "modal":    50,
    "toast":    60,
    "tooltip":  70
  },
  "component": {
    "nav": {
      "height":     "56px",
      "background": "rgba(8,14,28,0.97)",
      "backdrop":   "blur(20px)",
      "borderBottom": "1px solid var(--border)"
    },
    "card": {
      "background": "var(--navy-card)",
      "border":     "1px solid var(--border)",
      "radius":     "var(--radius-lg)",
      "accentLineTop": "2px gradient(--gold-dark, --gold, --gold-light)",
      "hover":      "translateY(-2px) + border-color var(--border-light)"
    },
    "button": {
      "primary": {
        "background": "var(--gold)",
        "color":      "var(--navy-deep)",
        "hover":      "var(--gold-light)",
        "active":     "var(--gold-dark)",
        "radius":     "var(--radius-md)",
        "padding":    "10px 20px",
        "fontWeight": 600
      },
      "secondary": {
        "background": "transparent",
        "color":      "var(--text-h)",
        "border":     "1px solid var(--border-light)",
        "hover":      "var(--navy-hover)"
      },
      "ghost": {
        "background": "transparent",
        "color":      "var(--text-secondary)",
        "hover":      "var(--navy-hover)"
      },
      "destructive": {
        "background": "var(--red)",
        "color":      "var(--white)"
      }
    },
    "input": {
      "background": "var(--navy-deep)",
      "border":     "1px solid var(--border)",
      "borderFocus":"1px solid var(--gold)",
      "color":      "var(--text-primary)",
      "placeholder":"var(--text-muted)",
      "radius":     "var(--radius-md)",
      "padding":    "10px 14px"
    },
    "badge": {
      "new":      { "border": "var(--green)",   "background": "rgba(15,186,127,0.08)",  "color": "var(--green)" },
      "updated":  { "border": "var(--gold)",    "background": "rgba(201,135,10,0.08)",  "color": "var(--gold)" },
      "critical": { "border": "var(--red)",     "background": "rgba(224,48,48,0.08)",   "color": "var(--red)" }
    },
    "alertBox": {
      "amber": { "background": "rgba(232,149,10,0.08)", "border": "rgba(232,149,10,0.22)" },
      "red":   { "background": "rgba(224,48,48,0.08)",  "border": "rgba(224,48,48,0.22)" },
      "green": { "background": "rgba(15,186,127,0.08)", "border": "rgba(15,186,127,0.22)" },
      "blue":  { "background": "rgba(59,130,246,0.08)", "border": "rgba(59,130,246,0.22)" }
    }
  },
  "accessibility": {
    "minContrastNormal": 4.5,
    "minContrastLarge": 3.0,
    "wcagTarget": "AA",
    "verified": {
      "textPrimary_on_navy":  { "ratio": 14.2, "pass": true },
      "textH_on_navy":        { "ratio": 16.8, "pass": true },
      "gold_on_navyDeep":     { "ratio": 6.1,  "pass": true },
      "textMuted_on_navy":    { "ratio": 3.4,  "pass": "large-only", "note": "Use only for ≥18px or 14px bold (WCAG AA large text)" }
    },
    "darkModeStance": "M0 ships light-on-dark only (navy is the canonical surface). True dark/light theme switch deferred to M2+."
  },
  "platform": {
    "scope": "WEB",
    "note": "M0 ships Web-only per DP-01. Mobile (apps/mobile/) will derive identical tokens at M2.S3 via NativeWind (DP-06 brand consistency)."
  }
}
